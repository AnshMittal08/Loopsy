{
  "rewrites": [
    {
      "source": "/p/:id",
      "has": [{ "type": "header", "key": "user-agent", "value": ".*(facebookexternalhit|Twitterbot|Slackbot|Discordbot|WhatsApp|TelegramBot|LinkedInBot|Pinterestbot|redditbot|SkypeUriPreview|vkShare).*" }],
      "destination": "https://loopsy-backend.up.railway.app/api/unfurl/p/:id"
    },
    {
      "source": "/d/:id",
      "has": [{ "type": "header", "key": "user-agent", "value": ".*(facebookexternalhit|Twitterbot|Slackbot|Discordbot|WhatsApp|TelegramBot|LinkedInBot|Pinterestbot|redditbot|SkypeUriPreview|vkShare).*" }],
      "destination": "https://loopsy-backend.up.railway.app/api/unfurl/d/:id"
    },
    {
      "source": "/u/:handle",
      "has": [{ "type": "header", "key": "user-agent", "value": ".*(facebookexternalhit|Twitterbot|Slackbot|Discordbot|WhatsApp|TelegramBot|LinkedInBot|Pinterestbot|redditbot|SkypeUriPreview|vkShare).*" }],
      "destination": "https://loopsy-backend.up.railway.app/api/unfurl/u/:handle"
    },
    {
      "source": "/api/:path*",
      "destination": "https://loopsy-backend.up.railway.app/api/:path*"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://loopsy-backend.up.railway.app/api/sitemap"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data: blob: https:; font-src 'self' https://fonts.gstatic.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; script-src 'self' 'wasm-unsafe-eval'; connect-src 'self' https://loopsy-backend.up.railway.app; worker-src 'self' blob:; manifest-src 'self'; upgrade-insecure-requests"
        },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    }
  ]
}
